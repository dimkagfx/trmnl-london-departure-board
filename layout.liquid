  <div class="flex flex-col w-full h-full p-4">
    {% if data.trains.size > 0 %}
      <table class="table w-full">
        <thead>
          <tr class="border-b-4 border-black text-xl uppercase tracking-wide">
            <th class="text-left pb-2"></th>
            <th class="text-left px-4 pb-2 w-3/5"><span class="title">Destination</span></th>
            <th class="text-right pb-2"><span class="title">Departs</span></th>
          </tr>
        </thead>
        <tbody>
          {% for train in data.trains limit: 7 %}
            <tr class="border-b-2 border-black">
              
              <!-- Transport Mode Icon -->
              <td class="py-3">
                {% if train.mode == 'Rail' %}
                  <!-- Train Icon for National Rail -->
                  <img class="w-10 h-10" src="data:image/svg+xml;base64," />
                {% else %}
                  <!-- Tram/Subway Icon for TfL / DLR -->
                  <img class="w-10 h-10" src="data:image/svg+xml;base64," />
                {% endif %}
              </td>

              <!-- Destination -->
              <td class="px-4 py-3">
                <span class="label text-3xl font-bold" data-clamp="1">{{ train.dest }}</span>
              </td>

              <!-- Time Logic -->
              <td class="text-right py-3">
                {% if train.is_cancelled %}
                  <span class="bg-black text-white rounded px-2 py-1 text-lg font-bold">Cancelled</span>
                {% elsif train.is_delayed %}
                  <span class="text-3xl font-bold">{{ train.estimated }}</span>
                  <span class="text-lg line-through ml-2">{{ train.scheduled }}</span>
                {% else %}
                  <span class="text-3xl font-bold">{{ train.scheduled }}</span>
                {% endif %}
              </td>
              
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      <!-- Empty State with Samoyed -->
      <div class="flex flex-col items-center justify-center h-full grow pb-8 mt-12">
        <div class="text-4xl font-bold mb-6">No departures right now.</div>
        <pre class="font-mono text-3xl leading-tight font-bold">
            ,-~~~-,
        .-'"       "'-.
      /               \
      |   ^         ^   |
      |  (O)       (O)  |
      |        A        |
      |      \___/      |
      \               /
        '-._       _.-'
            `"---"`
        </pre>
        <div class="text-2xl font-bold mt-6">Please enjoy this Samoyed.</div>
      </div>
    {% endif %}
  </div>
